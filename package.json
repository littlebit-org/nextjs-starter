{
  "name": "nextjs-starter-template",
  "description": "Starter template for Next.js 16 with shadcn/ui",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
